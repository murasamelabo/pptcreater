{
  "name": "pptcreater",
  "version": "0.5.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10"
  },
  "bin": {
    "pptcreater": "./packages/cli/dist/index.js"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "cli": "node packages/cli/dist/index.js",
    "mcp": "node packages/mcp-server/dist/index.js",
    "sample:schematics": "npm run build && node scripts/generate-schematic-pattern-samples.mjs",
    "studio": "node ./packages/cli/dist/index.js studio ./examples/deck.ja.json --output ./generated/studio.html"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^15.0.0",
    "pptxgenjs": "^4.0.1",
    "zod": "^4.4.3"
  }
}
